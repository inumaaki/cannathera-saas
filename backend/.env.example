DATABASE_URL="postgresql://user:password@localhost:5432/cannathera?schema=public"
JWT_SECRET="generate-a-long-random-secret"
# Local development only. Never enable this in production.
EXPOSE_DEV_AUTH_CODES=false
# Optional separate secret used to encrypt temporary onboarding credentials.
# Keep this stable; changing it makes still-pending credentials unreadable.
ONBOARDING_CREDENTIAL_SECRET="generate-another-long-random-secret"
WEB_ORIGIN="http://localhost:3000"
PORT=4000

# Number of trusted reverse-proxy hops in front of the API.
# Railway/Render/Fly deployments commonly use 1; keep 0 for direct local access.
TRUST_PROXY_HOPS=0

# SMTP / Email Configuration (GDPR-compliant, EU host recommended)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@cannathera.de"

# Zoom Server-to-Server OAuth Credentials
ZOOM_ACCOUNT_ID="your-zoom-account-id"
ZOOM_CLIENT_ID="your-zoom-client-id"
ZOOM_CLIENT_SECRET="your-zoom-client-secret"

