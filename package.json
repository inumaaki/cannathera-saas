{
  "name": "cannathera",
  "version": "0.0.0",
  "private": true,
  "description": "Cannathera — B2B SaaS platform for structured medical-cannabis therapy accompaniment",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "build": "pnpm --filter \"./apps/*\" build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "pnpm --filter @cannathera/db generate",
    "db:migrate": "pnpm --filter @cannathera/db migrate",
    "db:seed": "pnpm --filter @cannathera/db seed",
    "db:studio": "pnpm --filter @cannathera/db studio"
  },
  "devDependencies": {
    "prettier": "^3.4.2"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "puppeteer-core": "^25.3.0"
  }
}
